<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Github_Trend"
        xmlns:controls="using:Github_Trend.Controls"
        xmlns:loc="using:Github_Trend.Localization"
        xmlns:settingsPages="using:Github_Trend.Views.Settings"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Github_Trend.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        Width="1200" Height="800" MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterOwner" WindowState="Maximized" Title="Settings">

    <Window.Styles>
        <Style Selector="Border.settings-tab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.settings-tab:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
        </Style>
        <Style Selector="Border.settings-tab.selected">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        </Style>
        <Style Selector="Border.settings-tab.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        </Style>
        <Style Selector="Border.settings-card">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <Style Selector="Button.seg-control">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.seg-control:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
        </Style>
        <Style Selector="Button.seg-control.selected">
            <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.seg-control.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}" />
        </Style>
        <Style Selector="Button.log-filter">
            <Setter Property="Background" Value="{DynamicResource BackgroundSecondaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimaryBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.log-filter:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
        </Style>
        <Style Selector="Button.log-filter.active">
            <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimaryBrush}" />
        </Style>
        <Style Selector="Button.log-filter.active:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="0,0,0,0">
        <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="0,0,0,1" Padding="32,16,32,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/settings.svg" Width="24" Height="24" />
                    <TextBlock Text="Settings" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding SelectedPage.Description}" Foreground="{DynamicResource TextTertiaryBrush}"
                           FontSize="13" VerticalAlignment="Center" Margin="16,0,0,0" />
                <Border Grid.Column="2" Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="8" Padding="8,4"
                        IsVisible="{Binding Auth.IsConnected}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Background="{DynamicResource SuccessBrush}" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Auth.AccountSummary}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Row="1" ColumnDefinitions="280,Auto,*">
            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}" BorderThickness="0,0,1,0" Padding="10,8,10,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="2">
                        <ItemsControl ItemsSource="{Binding Pages}" Background="Transparent" BorderThickness="0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SettingsPage">
                                    <Border Classes="settings-tab" Classes.selected="{Binding IsSelected}" PointerPressed="OnTabPointerPressed" AutomationProperties.Name="{Binding Label}" Tag="{Binding}">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                            <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="8" Width="38" Height="38" VerticalAlignment="Center">
                                                <controls:SvgImage SourceUri="{Binding IconPath}" Width="20" Height="20" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" />
                                                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Border Grid.Column="1" Background="{DynamicResource BorderPrimaryBrush}" Width="1" />
            <Grid Grid.Column="2" Margin="0,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="36,24,36,24">
                    <StackPanel Spacing="0">
                        <settingsPages:AppearancePage x:Name="AppearancePageControl" IsVisible="{Binding IsAppearancePage}" />
                        <settingsPages:GeneralPage IsVisible="{Binding IsGeneralPage}" />
                        <settingsPages:AccountPage IsVisible="{Binding IsAccountPage}" />
                        <settingsPages:TrendingPage IsVisible="{Binding IsTrendingPage}" />
                        <settingsPages:CachePage IsVisible="{Binding IsCachePage}" />
                        <settingsPages:LogsPage x:Name="LogsPageControl" IsVisible="{Binding IsLogsPage}" />
                        <settingsPages:BackupPage IsVisible="{Binding IsBackupPage}" />
                        <settingsPages:AboutPage IsVisible="{Binding IsAboutPage}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>

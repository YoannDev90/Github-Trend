<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Github_Trend.Localization"
             xmlns:vm="using:Github_Trend"
             xmlns:controls="using:Github_Trend.Controls"
             x:Class="Github_Trend.Views.Main.SidebarPanel"
             x:DataType="vm:MainWindowViewModel">
    <StackPanel Spacing="6">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4" Margin="4,4,4,2">
            <TextBlock Text="GitHub Trend" Foreground="{DynamicResource TextPrimaryBrush}"
                       FontWeight="Bold" FontSize="{DynamicResource FontSizeLarge}" VerticalAlignment="Center" />
            <Button Grid.Column="1" Command="{Binding Auth.SignInCommand}" Width="32" Height="32" Padding="0"
                    Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0"
                    CornerRadius="{DynamicResource CornerSmall}"
                    AutomationProperties.Name="Sign in with GitHub">
                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/github.svg" Width="16" Height="16" />
            </Button>
            <Button Grid.Column="2" Click="OnSettingsButtonClick" Width="32" Height="32" Padding="0"
                    Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0"
                    CornerRadius="{DynamicResource CornerSmall}"
                    AutomationProperties.Name="Settings">
                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/settings.svg" Width="16" Height="16" />
            </Button>
        </Grid>

        <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="8" Padding="0">
            <TextBox x:Name="SearchTextBox"
                     Text="{Binding Filter.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="{Binding Source={x:Static loc:Localization.Instance}, Path=SearchPlaceholderText}"
                     Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
                     BorderThickness="0" CaretBrush="{DynamicResource AccentSecondaryBrush}"
                     FontSize="{DynamicResource FontSizeSmall}" Padding="10,8"
                     AutomationProperties.Name="Search repositories" />
        </Border>

        <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="8" Padding="3">
            <Border.Styles>
                <Style Selector="Button.time-segment">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Padding" Value="0,6" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="13" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                                <TextBlock Text="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter>
                </Style>
                <Style Selector="Button.time-segment:pointerover">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                </Style>
                <Style Selector="Button.time-segment.selected">
                    <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                </Style>
                <Style Selector="Button.time-segment.selected:pointerover">
                    <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}" />
                </Style>
            </Border.Styles>
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="0">
                <Button Classes="time-segment" Classes.selected="{Binding IsDailySelected}"
                        Command="{Binding SelectDailyCommand}"
                        Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeDaily}"
                        CornerRadius="6,0,0,6"
                        AutomationProperties.Name="Daily time range" />
                <Button Grid.Column="1" Classes="time-segment" Classes.selected="{Binding IsWeeklySelected}"
                        Command="{Binding SelectWeeklyCommand}"
                        Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeWeekly}"
                        AutomationProperties.Name="Weekly time range" />
                <Button Grid.Column="2" Classes="time-segment" Classes.selected="{Binding IsMonthlySelected}"
                        Command="{Binding SelectMonthlyCommand}"
                        Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeMonthly}"
                        AutomationProperties.Name="Monthly time range" />
                <Button Grid.Column="3" Classes="time-segment" Classes.selected="{Binding IsAllSelected}"
                        Command="{Binding SelectAllCommand}"
                        Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeAll}"
                        CornerRadius="0,6,6,0"
                        AutomationProperties.Name="All time range" />
            </Grid>
        </Border>

        <Border Background="{DynamicResource BackgroundTertiaryBrush}" CornerRadius="8" Padding="0" MinHeight="200">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                <Border Padding="10,8,8,6">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                        <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SuggestionsTitle}"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"
                                   FontSize="{DynamicResource FontSizeSmall}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Filter.SelectedCount, StringFormat='{}{0}'}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" FontSize="{DynamicResource FontSizeXSmall}" VerticalAlignment="Center" />
                        <Button Grid.Column="2" Command="{Binding Filter.SelectAllCommand}" Content="All"
                                Padding="0" Background="Transparent" Foreground="{DynamicResource AccentSecondaryBrush}"
                                BorderThickness="0" FontSize="{DynamicResource FontSizeXSmall}" FontWeight="SemiBold"
                                AutomationProperties.Name="Select all languages" />
                        <Button Grid.Column="3" Command="{Binding Filter.DeselectAllCommand}" Content="None"
                                Padding="0" Background="Transparent" Foreground="{DynamicResource TextTertiaryBrush}"
                                BorderThickness="0" FontSize="{DynamicResource FontSizeXSmall}" FontWeight="SemiBold"
                                AutomationProperties.Name="Deselect all languages" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Height="1" Background="{DynamicResource BackgroundSecondaryBrush}" HorizontalAlignment="Stretch" />
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="4,2,4,4">
                    <ItemsControl ItemsSource="{Binding Filter.FilteredLanguages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                <Border CornerRadius="6" Padding="8,5" Margin="0,0,0,1">
                                    <Border.Styles>
                                        <Style Selector="Border"><Setter Property="Background" Value="Transparent" /></Style>
                                        <Style Selector="Border:pointerover"><Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" /></Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="8,*,Auto" ColumnSpacing="10">
                                        <Border Background="{Binding AccentBrush}" CornerRadius="4" Width="8" Height="8" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Language}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="{DynamicResource FontSizeSmall}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center"
                                                  AutomationProperties.Name="{Binding Language}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>

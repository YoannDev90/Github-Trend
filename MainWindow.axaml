<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Github_Trend"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="820"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Github_Trend.MainWindow"
        Background="#FF020617"
        Title="Github_Trend">
    <Grid ColumnDefinitions="360,*">
        <Border Background="#FF0B1220"
                BorderBrush="#FF1F2937"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18" Spacing="16">
                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <StackPanel Spacing="2">
                                <TextBlock Text="GitHub Account"
                                           Foreground="White"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Connecte-toi via le flux loopback local"
                                           Foreground="#FF94A3B8"
                                           FontSize="11"/>
                            </StackPanel>

                            <TextBlock Text="{Binding GitHubAuthStatus}"
                                       Foreground="#FFE5E7EB"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding GitHubAccountSummary}"
                                       Foreground="#FF94A3B8"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{Binding GitHubSignInCommand}"
                                        Padding="10,6"
                                        Background="#FF1D4ED8"
                                        Foreground="White"
                                        BorderBrush="#FF60A5FA"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <TextBlock Text="Sign in with GitHub" FontWeight="SemiBold"/>
                                </Button>

                                <Button Command="{Binding GitHubRefreshCommand}"
                                        Padding="10,6"
                                        Background="#FF0F172A"
                                        Foreground="#FFE5E7EB"
                                        BorderBrush="#FF334155"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        IsVisible="{Binding IsGitHubConnected}">
                                    <TextBlock Text="Refresh token" FontWeight="SemiBold"/>
                                </Button>

                                <Button Command="{Binding GitHubSignOutCommand}"
                                        Padding="10,6"
                                        Background="#FF111827"
                                        Foreground="#FFFCA5A5"
                                        BorderBrush="#FF7F1D1D"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        IsVisible="{Binding IsGitHubConnected}">
                                    <TextBlock Text="Sign out" FontWeight="SemiBold"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Recherche"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Ex : JavaScript, Rust..."
                                     Background="#FF020617"
                                     Foreground="#FFE5E7EB"
                                     BorderBrush="#FF334155"
                                     CaretBrush="#FF93C5FD"
                                     CornerRadius="8"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Spacing="2">
                                    <TextBlock Text="Période du trending"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Choisis la fenêtre de temps"
                                               Foreground="#FF94A3B8"
                                               FontSize="11"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#0B1220"
                                    BorderBrush="#243244"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="8">
                                <Grid ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8"
                                      RowSpacing="8">
                                    <Button x:Name="DailyTimeRangeButton"
                                                 Click="OnTimeRangeButtonClick"
                                                 Tag="0"
                                                 Content="Daily"
                                                 Height="44"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 Padding="12"
                                                 Background="#111827"
                                                 Foreground="#CBD5E1"
                                                 BorderBrush="#334155"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FontWeight="SemiBold"
                                                 Classes="time-range-pill"/>
                                    <Button x:Name="WeeklyTimeRangeButton"
                                                 Grid.Row="0" Grid.Column="1"
                                                 Click="OnTimeRangeButtonClick"
                                                 Tag="1"
                                                 Content="Weekly"
                                                 Height="44"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 Padding="12"
                                                 Background="#111827"
                                                 Foreground="#CBD5E1"
                                                 BorderBrush="#334155"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FontWeight="SemiBold"
                                                 Classes="time-range-pill"/>
                                    <Button x:Name="MonthlyTimeRangeButton"
                                                 Grid.Row="1" Grid.Column="0"
                                                 Click="OnTimeRangeButtonClick"
                                                 Tag="2"
                                                 Content="Monthly"
                                                 Height="44"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 Padding="12"
                                                 Background="#111827"
                                                 Foreground="#CBD5E1"
                                                 BorderBrush="#334155"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FontWeight="SemiBold"
                                                 Classes="time-range-pill"/>
                                    <Button x:Name="AllTimeRangeButton"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Click="OnTimeRangeButtonClick"
                                                 Tag="3"
                                                 Content="All"
                                                 Height="44"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Center"
                                                 Padding="12"
                                                 Background="#111827"
                                                 Foreground="#CBD5E1"
                                                 BorderBrush="#334155"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 FontWeight="SemiBold"
                                                 Classes="time-range-pill"/>
                                    <Grid.Styles>
                                        <Style Selector="Button.time-range-pill:pointerover">
                                            <Setter Property="Background" Value="#1F2937"/>
                                            <Setter Property="BorderBrush" Value="#60A5FA"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </Grid.Styles>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Sélectionnés"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#FF1D4ED8"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding SelectedCount}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedLanguages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                        <Border Background="{Binding AccentBrush}"
                                                CornerRadius="999"
                                                Padding="10,6"
                                                Margin="0,0,6,6">
                                            <TextBlock Text="{Binding Language}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Text="Suggestions"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#FF334155"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding VisibleCount}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding RefreshCommand}"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        Background="#FF1F2937"
                                        Foreground="White"
                                        BorderBrush="#FF334155"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Classes="refresh-button">
                                    <Button.Styles>
                                        <Style Selector="Button.refresh-button:pointerover">
                                            <Setter Property="Background" Value="#FF334155"/>
                                            <Setter Property="BorderBrush" Value="#FF60A5FA"/>
                                        </Style>
                                        <Style Selector="Button.refresh-button:pressed">
                                            <Setter Property="Background" Value="#FF0F172A"/>
                                        </Style>
                                    </Button.Styles>
                                    <TextBlock Text="Rafraîchir" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding MatchingLanguagesLabel}"
                                       Foreground="#FF94A3B8"
                                       FontSize="12"/>

                            <Border Background="#FF020617"
                                    CornerRadius="16"
                                    BorderBrush="#FF1F2937"
                                    BorderThickness="1"
                                    Padding="10">
                                <ScrollViewer Height="320"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                                <Border Background="#FF0F172A"
                                                        BorderBrush="#FF243244"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="6,*,Auto"
                                                          ColumnSpacing="12">
                                                        <Border Background="{Binding AccentBrush}"
                                                                CornerRadius="999"
                                                                Width="6"/>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="4"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Language}"
                                                                       Foreground="#FFF8FAFC"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Foreground="#FFF8FAFC"
                                                                  VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Background="#FF020617"
                      Padding="20"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <Border Background="#FF0B1220"
                        BorderBrush="#FF1F2937"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="22">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="Repos GitHub Trending"
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding TrendingLabel}"
                                           Foreground="#FF94A3B8"
                                           FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <Border Background="#FF0B1220"
                        BorderBrush="#FF1F2937"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="22">
                    <StackPanel Spacing="12">
                        <ItemsControl ItemsSource="{Binding TrendingRepositories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GithubTrendingRepository">
                                    <Border Background="#FF0F172A"
                                            BorderBrush="#FF243244"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="0"
                                            Margin="0,0,0,12"
                                            ClipToBounds="True"
                                            MinHeight="240">
                                        <Grid ColumnDefinitions="1.25*,1.75*"
                                              MinHeight="240">
                                            <Border Background="#FF111827"
                                                    CornerRadius="14,0,0,14"
                                                    MinHeight="240"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding BannerImage}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="12"
                                                        Margin="18"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding DisplayTitle}"
                                                                   Foreground="#FFF8FAFC"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="18"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="#FF94A3B8"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Click="OnOpenRepositoryClick"
                                                            Padding="12,8"
                                                            Background="#FF1D4ED8"
                                                            Foreground="White"
                                                            BorderBrush="#FF60A5FA"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="↗ Ouvrir" FontWeight="SemiBold"/>
                                                    </Button>
                                                </Grid>

                                                <StackPanel Spacing="8"
                                                            IsVisible="{Binding HasContributors}">
                                                    <TextBlock Text="Contributeurs"
                                                               Foreground="#FFCBD5E1"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Opacity="0.9"/>

                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <ItemsControl ItemsSource="{Binding Contributors}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:GithubContributorPreview">
                                                                    <Border Width="32"
                                                                            Height="32"
                                                                            CornerRadius="999"
                                                                            ClipToBounds="True"
                                                                            Margin="0,0,6,0"
                                                                            BorderBrush="#FF334155"
                                                                            BorderThickness="1">
                                                                        <Image Source="{Binding AvatarImage}"
                                                                               Stretch="UniformToFill"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <Border Grid.Column="1"
                                                                Background="#FF1F2937"
                                                                CornerRadius="999"
                                                                Padding="10,5"
                                                                VerticalAlignment="Center"
                                                                IsVisible="{Binding HasRemainingContributors}">
                                                            <TextBlock Text="{Binding RemainingContributorsLabel}"
                                                                       Foreground="#FFE5E7EB"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>

                                                <WrapPanel>
                                                    <Border Background="{Binding LanguageBrush}"
                                                            CornerRadius="999"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LanguageBadgeText}"
                                                                   Foreground="White"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                    <Border Background="#FF1F2937"
                                                            CornerRadius="999"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LicenseBadgeText}"
                                                                   Foreground="#FFE5E7EB"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                    <Border Background="#FF334155"
                                                            CornerRadius="999"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LastUpdatedBadgeText}"
                                                                   Foreground="#FFE5E7EB"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                </WrapPanel>

                                                <ItemsControl ItemsSource="{Binding Topics}"
                                                              IsVisible="{Binding HasTopics}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF111827"
                                                                    BorderBrush="#FF334155"
                                                                    BorderThickness="1"
                                                                    CornerRadius="999"
                                                                    Padding="10,5"
                                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="#FFF8FAFC"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                                                    <Border Background="#FF111827"
                                                            BorderBrush="#FF334155"
                                                            BorderThickness="1"
                                                            CornerRadius="999"
                                                            Padding="10,6">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="★" Foreground="#FFFBBF24" FontSize="12"/>
                                                            <TextBlock Text="{Binding StarsLabel}"
                                                                       Foreground="#FFF8FAFC"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Column="1"
                                                            Background="#FF111827"
                                                            BorderBrush="#FF334155"
                                                            BorderThickness="1"
                                                            CornerRadius="999"
                                                            Padding="10,6">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="⎇" Foreground="#FF93C5FD" FontSize="12"/>
                                                            <TextBlock Text="{Binding ForksLabel}"
                                                                       Foreground="#FFF8FAFC"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

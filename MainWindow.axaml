<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="MainWindowRoot"
        xmlns:vm="using:Github_Trend"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:controls="using:Github_Trend.Controls"
         xmlns:loc="using:Github_Trend.Localization"
         xmlns:converters="using:Github_Trend"
        mc:Ignorable="d"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Github_Trend.MainWindow"
         Background="{DynamicResource BackgroundPrimaryBrush}"
         UseLayoutRounding="True"
         WindowState="Maximized"
         Icon="avares://Github-Trend/Assets/icon.ico"
         Title="GitHub Trend"
         KeyDown="OnWindowKeyDown">
    <Window.Resources>
        <converters:BoolToStarredBrushConverter x:Key="StarredBrushConverter" />
        <converters:BoolToWatchedBrushConverter x:Key="WatchedBrushConverter" />
    </Window.Resources>
    <Window.Styles>
        <Style Selector="Border.repo-card">
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Button.repo-action-button">
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style Selector="Button.repo-action-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
        </Style>
        <Style Selector="Button.repo-action-button:pressed">
            <Setter Property="Background" Value="{DynamicResource PressedBackgroundBrush}" />
        </Style>
        <Style Selector="Button.repo-action-button:disabled">
            <Setter Property="Opacity" Value="0.5" />
        </Style>
    </Window.Styles>
    <Grid RowDefinitions="*,Auto">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" MinWidth="260" MaxWidth="500" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="0,0,0.5,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ClipToBounds="True">
                <StackPanel Margin="12" Spacing="6">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4"
                          Margin="4,4,4,2">
                        <TextBlock Text="GitHub Trend"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="Bold"
                                   FontSize="{DynamicResource FontSizeLarge}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Command="{Binding Auth.SignInCommand}"
                                Width="32" Height="32"
                                Padding="0"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                BorderThickness="0"
                                CornerRadius="{DynamicResource CornerSmall}">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/github.svg"
                                               Width="16" Height="16" />
                        </Button>
                        <Button Grid.Column="2"
                                Click="OnSettingsButtonClick"
                                Width="32" Height="32"
                                Padding="0"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                BorderThickness="0"
                                CornerRadius="{DynamicResource CornerSmall}">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/settings.svg"
                                               Width="16" Height="16" />
                        </Button>
                    </Grid>

                    <!-- Search -->
                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                            CornerRadius="8"
                            Padding="0">
                        <TextBox x:Name="SearchTextBox"
                                 Text="{Binding Filter.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="{Binding Source={x:Static loc:Localization.Instance}, Path=SearchPlaceholderText}"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0"
                                 CaretBrush="{DynamicResource AccentSecondaryBrush}"
                                 FontSize="{DynamicResource FontSizeSmall}"
                                 Padding="10,8" />
                    </Border>

                    <!-- Trending Period -->
                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                            CornerRadius="8"
                            Padding="3">
                        <Border.Styles>
                            <Style Selector="Button.time-segment">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="Padding" Value="0,6" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="{TemplateBinding CornerRadius}"
                                                Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                            <Style Selector="Button.time-segment:pointerover">
                                <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                            </Style>
                            <Style Selector="Button.time-segment.selected">
                                <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Style>
                            <Style Selector="Button.time-segment.selected:pointerover">
                                <Setter Property="Background" Value="{DynamicResource BackgroundPrimaryBrush}" />
                            </Style>
                        </Border.Styles>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="0">
                            <Button Classes="time-segment"
                                    Classes.selected="{Binding IsDailySelected}"
                                    Command="{Binding SelectDailyCommand}"
                                    Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeDaily}"
                                    CornerRadius="6,0,0,6" />
                            <Button Grid.Column="1"
                                    Classes="time-segment"
                                    Classes.selected="{Binding IsWeeklySelected}"
                                    Command="{Binding SelectWeeklyCommand}"
                                    Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeWeekly}" />
                            <Button Grid.Column="2"
                                    Classes="time-segment"
                                    Classes.selected="{Binding IsMonthlySelected}"
                                    Command="{Binding SelectMonthlyCommand}"
                                    Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeMonthly}" />
                            <Button Grid.Column="3"
                                    Classes="time-segment"
                                    Classes.selected="{Binding IsAllSelected}"
                                    Command="{Binding SelectAllCommand}"
                                    Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeAll}"
                                    CornerRadius="0,6,6,0" />
                        </Grid>
                    </Border>

                    <!-- Languages -->
                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                            CornerRadius="8"
                            Padding="0"
                            MinHeight="200">
                        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">
                            <!-- Header row -->
                            <Border Padding="10,8,8,6">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
                                    <TextBlock
                                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SuggestionsTitle}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        FontWeight="SemiBold"
                                        FontSize="{DynamicResource FontSizeSmall}"
                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Filter.SelectedCount, StringFormat='{}{0}'}"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               FontSize="{DynamicResource FontSizeXSmall}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="2"
                                            Command="{Binding Filter.SelectAllCommand}"
                                            Content="All"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource AccentSecondaryBrush}"
                                            BorderThickness="0"
                                            FontSize="{DynamicResource FontSizeXSmall}"
                                            FontWeight="SemiBold" />
                                    <Button Grid.Column="3"
                                            Command="{Binding Filter.DeselectAllCommand}"
                                            Content="None"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource TextTertiaryBrush}"
                                            BorderThickness="0"
                                            FontSize="{DynamicResource FontSizeXSmall}"
                                            FontWeight="SemiBold" />
                                </Grid>
                            </Border>

                            <!-- Separator -->
                            <Border Grid.Row="1"
                                    Height="1"
                                    Background="{DynamicResource BackgroundSecondaryBrush}"
                                    HorizontalAlignment="Stretch" />

                            <!-- Language list -->
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="4,2,4,4">
                                <ItemsControl ItemsSource="{Binding Filter.FilteredLanguages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                            <Border CornerRadius="6"
                                                    Padding="8,5"
                                                    Margin="0,0,0,1">
                                                <Border.Styles>
                                                    <Style Selector="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                    </Style>
                                                    <Style Selector="Border:pointerover">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                                                    </Style>
                                                </Border.Styles>
                                                <Grid ColumnDefinitions="8,*,Auto"
                                                      ColumnSpacing="10">
                                                    <Border Background="{Binding AccentBrush}"
                                                            CornerRadius="4"
                                                            Width="8"
                                                            Height="8"
                                                            VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Language}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="{DynamicResource FontSizeSmall}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <CheckBox Grid.Column="2"
                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1"
                       Width="4"
                       Background="Transparent"
                       ResizeDirection="Columns"
                       ResizeBehavior="PreviousAndNext" />

        <ScrollViewer x:Name="TrendingScrollViewer"
                       Grid.Column="2"
                       Background="{DynamicResource BackgroundPrimaryBrush}"
                       Padding="20"
                       VerticalScrollBarVisibility="Auto"
                       HorizontalScrollBarVisibility="Disabled"
                       ClipToBounds="True">
            <StackPanel Spacing="16"
                        Width="{Binding Viewport.Width, ElementName=TrendingScrollViewer}">
                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderPrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerXLarge}"
                        Margin="8,0,8,0"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Padding="{DynamicResource PaddingXLarge}">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="12">
                        <StackPanel Grid.Row="0" Spacing="6">
                            <TextBlock
                                Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingRepositoriesTitle}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="{DynamicResource FontSizeXLarge}"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Top">
                            <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerPill}"
                                    Padding="10,5">
                                <TextBlock Text="{Binding Filter.SelectedCount}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="{DynamicResource FontSizeXSmall}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerPill}"
                                    Padding="10,5">
                                <TextBlock Text="{Binding Filter.VisibleCount}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="{DynamicResource FontSizeXSmall}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding TrendingLabel}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{DynamicResource FontSizeSmall}" />
                    </Grid>
                </Border>

                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderPrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerXLarge}"
                        Margin="8,0,8,0"
                        Padding="{DynamicResource PaddingXLarge}">
                    <StackPanel Spacing="12">

                        <!-- Loading state -->
                        <Border IsVisible="{Binding ShowTrendingLoading}"
                                Padding="40"
                                HorizontalAlignment="Center">
                            <StackPanel Spacing="12"
                                        HorizontalAlignment="Center">
                                <ProgressBar IsIndeterminate="True"
                                             Width="200"
                                             Height="4"
                                             Foreground="{DynamicResource AccentPrimaryBrush}"
                                             Background="{DynamicResource BackgroundTertiaryBrush}" />
                                <TextBlock Text="Loading trending repositories..."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSizeSmall}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Empty state -->
                        <Border IsVisible="{Binding ShowTrendingEmpty}"
                                Padding="40"
                                HorizontalAlignment="Center">
                            <StackPanel Spacing="8"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="No repositories found"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="{DynamicResource FontSizeLarge}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Try changing your language filter or trending period."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="{DynamicResource FontSizeSmall}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Repository list -->
                        <ItemsControl x:Name="TrendingItemsControl"
                                      IsVisible="{Binding ShowTrendingContent}"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding TrendingRepositories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GithubTrendingRepository">
                                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource CornerMedium}"
                                            Padding="0"
                                            Margin="0,0,0,12"
                                            Classes="repo-card"
                                            ClipToBounds="True"
                                            MinHeight="240">
                                        <Grid ColumnDefinitions="1.25*,1.75*,160"
                                              MinHeight="240">
                                            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                    CornerRadius="14,0,0,14"
                                                    MinHeight="240"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding BannerImage}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="12"
                                                        Margin="18"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontWeight="SemiBold"
                                                               FontSize="{DynamicResource FontSizeLarge}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{DynamicResource FontSizeSmall}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <StackPanel Spacing="8"
                                                            IsVisible="{Binding HasContributors}">
                                                    <TextBlock
                                                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=ContributorsTitle}"
                                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                                        FontSize="{DynamicResource FontSizeXSmall}"
                                                        FontWeight="SemiBold"
                                                        Opacity="0.9" />

                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <ItemsControl ItemsSource="{Binding Contributors}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:GithubContributorPreview">
                                                                    <Border Width="32"
                                                                            Height="32"
                                                                            CornerRadius="{DynamicResource CornerPill}"
                                                                            ClipToBounds="True"
                                                                            Margin="0,0,6,0"
                                                                            BorderBrush="{DynamicResource BorderSecondaryBrush}"
                                                                            BorderThickness="1">
                                                                        <Image Source="{Binding AvatarImage}"
                                                                               Stretch="UniformToFill" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </Grid>
                                                </StackPanel>

                                                <WrapPanel>
                                                    <Border Background="{Binding LanguageBrush}"
                                                            CornerRadius="{DynamicResource CornerPill}"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LanguageBadgeText}"
                                                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>

                                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                            CornerRadius="{DynamicResource CornerPill}"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LicenseBadgeText}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>

                                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                            CornerRadius="{DynamicResource CornerPill}"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LastUpdatedBadgeText}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>

                                                </WrapPanel>

                                                <ItemsControl ItemsSource="{Binding Topics}"
                                                              IsVisible="{Binding HasTopics}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{DynamicResource CornerPill}"
                                                                    Padding="10,5"
                                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           FontSize="{DynamicResource FontSizeXSmall}"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="{DynamicResource BackgroundPrimaryBrush}"
                                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                    BorderThickness="1,0,0,0"
                                                    Padding="{DynamicResource PaddingLarge}"
                                                    ClipToBounds="True">
                                                <StackPanel Spacing="8"
                                                            VerticalAlignment="Top">
                                                    <Button Classes="repo-action-button"
                                                             HorizontalAlignment="Stretch"
                                                             ToolTip.Tip="Open in browser"
                                                             Command="{Binding ViewModel.OpenRepositoryCommand, ElementName=MainWindowRoot}"
                                                             CommandParameter="{Binding}">
                                                         <controls:SvgImage
                                                             SourceUri="avares://Github-Trend/Assets/Icons/open.svg"
                                                             Width="22"
                                                             Height="22" />
                                                     </Button>

                                                     <Button Classes="repo-action-button"
                                                             HorizontalAlignment="Stretch"
                                                             ToolTip.Tip="Star on GitHub"
                                                             Background="{Binding IsStarred, Converter={StaticResource StarredBrushConverter}}"
                                                             Command="{Binding ViewModel.StarRepositoryCommand, ElementName=MainWindowRoot}"
                                                             CommandParameter="{Binding}">
                                                         <controls:SvgImage
                                                             SourceUri="avares://Github-Trend/Assets/Icons/star.svg"
                                                             Width="22"
                                                             Height="22" />
                                                     </Button>

                                                     <Button Classes="repo-action-button"
                                                             HorizontalAlignment="Stretch"
                                                             ToolTip.Tip="Watch on GitHub"
                                                             Background="{Binding IsWatched, Converter={StaticResource WatchedBrushConverter}}"
                                                             Command="{Binding ViewModel.WatchRepositoryCommand, ElementName=MainWindowRoot}"
                                                             CommandParameter="{Binding}">
                                                         <controls:SvgImage
                                                             SourceUri="avares://Github-Trend/Assets/Icons/watch.svg"
                                                             Width="22"
                                                             Height="22" />
                                                     </Button>

                                                     <Button Classes="repo-action-button"
                                                              HorizontalAlignment="Stretch"
                                                              ToolTip.Tip="Dismiss"
                                                              Command="{Binding ViewModel.DismissRepositoryCommand, ElementName=MainWindowRoot}"
                                                              CommandParameter="{Binding}">
                                                          <controls:SvgImage
                                                              SourceUri="avares://Github-Trend/Assets/Icons/delete.svg"
                                                              Width="22"
                                                              Height="22" />
                                                      </Button>

                                                      <Button Classes="repo-action-button"
                                                              HorizontalAlignment="Stretch"
                                                              ToolTip.Tip="Save for later"
                                                              Command="{Binding ViewModel.SaveRepositoryCommand, ElementName=MainWindowRoot}"
                                                              CommandParameter="{Binding}">
                                                          <controls:SvgImage
                                                              SourceUri="avares://Github-Trend/Assets/Icons/save.svg"
                                                              Width="22"
                                                              Height="22" />
                                                      </Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="{DynamicResource FontSizeSmall}"
                       TextTrimming="CharacterEllipsis" />
        </Border>
    </Grid>
</Window>

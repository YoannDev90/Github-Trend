<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Github_Trend"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="820"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Github_Trend.MainWindow"
        Background="#FF020617"
        Title="Github_Trend">
    <Grid ColumnDefinitions="360,*">
        <Border Background="#FF0B1220"
                BorderBrush="#FF1F2937"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18"
                            Spacing="16">

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Recherche"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Ex : JavaScript, Rust..."
                                     Background="#FF020617"
                                     Foreground="#FFE5E7EB"
                                     BorderBrush="#FF334155"
                                     CaretBrush="#FF93C5FD"
                                     CornerRadius="8"
                                     />
                        </StackPanel>
                    </Border>

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Sélectionnés"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#FF1D4ED8"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding SelectedCount}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedLanguages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                        <Border Background="{Binding AccentBrush}"
                                                CornerRadius="999"
                                                Padding="10,6"
                                                Margin="0,0,6,6">
                                            <TextBlock Text="{Binding Language}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF111827"
                            BorderBrush="#FF243244"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Text="Suggestions"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#FF334155"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding VisibleCount}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding RefreshCommand}"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        Background="#FF1F2937"
                                        Foreground="White"
                                        BorderBrush="#FF334155"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Classes="refresh-button">
                                    <Button.Styles>
                                        <Style Selector="Button.refresh-button:pointerover">
                                            <Setter Property="Background" Value="#FF334155"/>
                                            <Setter Property="BorderBrush" Value="#FF60A5FA"/>
                                        </Style>
                                        <Style Selector="Button.refresh-button:pressed">
                                            <Setter Property="Background" Value="#FF0F172A"/>
                                        </Style>
                                    </Button.Styles>
                                    <TextBlock Text="Rafraîchir" FontWeight="SemiBold"/>
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding MatchingLanguagesLabel}"
                                       Foreground="#FF94A3B8"
                                       FontSize="12"/>

                            <Border Background="#FF020617"
                                    CornerRadius="16"
                                    BorderBrush="#FF1F2937"
                                    BorderThickness="1"
                                    Padding="10">
                                <ScrollViewer Height="320"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                                <Border Background="#FF0F172A"
                                                        BorderBrush="#FF243244"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="6,*,Auto"
                                                          ColumnSpacing="12">
                                                        <Border Background="{Binding AccentBrush}"
                                                                CornerRadius="999"
                                                                Width="6"/>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="4">
                                                            <TextBlock Text="{Binding Language}"
                                                                       Foreground="#FFF8FAFC"
                                                                       FontWeight="SemiBold"/>
                                                        </StackPanel>

                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Foreground="#FFF8FAFC"
                                                                  VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Background="#FF020617"
                      Padding="20"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <Border Background="#FF0B1220"
                        BorderBrush="#FF1F2937"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="22">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="Repos GitHub Trending" 
                                           Foreground="White"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <Border Background="#FF0B1220"
                        BorderBrush="#FF1F2937"
                        BorderThickness="1"
                        CornerRadius="24"
                        Padding="22">
                    <StackPanel Spacing="12">

                        <ScrollViewer Height="600"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TrendingRepositories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:GithubTrendingRepository">
                                        <Border Background="#FF0F172A"
                                                BorderBrush="#FF243244"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="14"
                                                Margin="0,0,0,10">
                                            <StackPanel Spacing="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Repository}"
                                                               Foreground="#FFF8FAFC"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#FF94A3B8"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"
                                                               MaxHeight="40"/>
                                                </StackPanel>

                                                <Grid ColumnDefinitions="Auto,Auto,Auto,*"
                                                      ColumnSpacing="12">
                                                    <Border Background="#FF1D4ED8"
                                                            CornerRadius="999"
                                                            Padding="8,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="⭐" Foreground="White"/>
                                                            <TextBlock Text="{Binding Stars}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Grid.Column="1"
                                                            Background="#FF334155"
                                                            CornerRadius="999"
                                                            Padding="8,4">
                                                        <TextBlock Text="{Binding Language}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="11"/>
                                                    </Border>

                                                    <Border Grid.Column="2"
                                                            Background="#FF334155"
                                                            CornerRadius="999"
                                                            Padding="8,4">
                                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                                            <TextBlock Text="📈" Foreground="White"/>
                                                            <TextBlock Text="{Binding Increased}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

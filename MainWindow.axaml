<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="MainWindowRoot"
        xmlns:vm="using:Github_Trend"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:Github_Trend.Controls"
        xmlns:loc="using:Github_Trend.Localization"
        mc:Ignorable="d"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Github_Trend.MainWindow"
        Background="#FF0D1117"
        UseLayoutRounding="True"
        WindowState="Maximized"
        Icon="avares://Github-Trend/Assets/icon.ico"
        Title="GitHub Trend">
    <Window.Styles>
        <Style Selector="Border.repo-card">
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="Button.repo-action-button">
            <Setter Property="Background" Value="#FF21262D"/>
            <Setter Property="BorderBrush" Value="#FF30363D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.repo-action-button:pointerover">
            <Setter Property="Background" Value="#FF30363D"/>
            <Setter Property="BorderBrush" Value="#FF8B949E"/>
        </Style>
    </Window.Styles>
    <Grid ColumnDefinitions="360,*">
        <Border Background="#FF161B22"
                BorderBrush="#FF30363D"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ClipToBounds="True">
                <StackPanel Margin="16" Spacing="14">

                    <!-- Settings Button & Profile Header -->
                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="GitHub Trend"
                                       Foreground="#FFC9D1D9"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Command="{Binding GitHubSignInCommand}"
                                    Padding="8"
                                    Background="#FF238636"
                                    Foreground="White"
                                    BorderBrush="#FF2EA043"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/github.svg"
                                                   Width="18"
                                                   Height="18"/>
                            </Button>
                            <Button Grid.Column="2"
                                    Click="OnSettingsButtonClick"
                                    Margin="8,0,0,0"
                                    Padding="8"
                                    Background="#FF21262D"
                                    Foreground="#FFC9D1D9"
                                    BorderBrush="#FF30363D"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/settings.svg"
                                                   Width="18"
                                                   Height="18"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SearchTitle}"
                                       Foreground="#FFC9D1D9"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="#FF0D1117"
                                     Foreground="#FFC9D1D9"
                                     BorderBrush="#FF30363D"
                                     CaretBrush="#FF2EA043"
                                     CornerRadius="8"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Spacing="2">
                                    <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingPeriodTitle}"
                                               Foreground="#FFC9D1D9"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingPeriodSubtitle}"
                                               Foreground="#FF8B949E"
                                               FontSize="11"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#FF0D1117"
                                    BorderBrush="#FF30363D"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="8">
                                <Grid ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8"
                                      RowSpacing="8">
                                    <Button x:Name="DailyTimeRangeButton"
                                            Click="OnTimeRangeButtonClick"
                                            Tag="0"
                                            Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeDaily}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            Background="#FF21262D"
                                            Foreground="#FFC9D1D9"
                                            BorderBrush="#FF30363D"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"/>
                                    <Button x:Name="WeeklyTimeRangeButton"
                                            Grid.Row="0" Grid.Column="1"
                                            Click="OnTimeRangeButtonClick"
                                            Tag="1"
                                            Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeWeekly}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            Background="#FF21262D"
                                            Foreground="#FFC9D1D9"
                                            BorderBrush="#FF30363D"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"/>
                                    <Button x:Name="MonthlyTimeRangeButton"
                                            Grid.Row="1" Grid.Column="0"
                                            Click="OnTimeRangeButtonClick"
                                            Tag="2"
                                            Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeMonthly}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            Background="#FF21262D"
                                            Foreground="#FFC9D1D9"
                                            BorderBrush="#FF30363D"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"/>
                                    <Button x:Name="AllTimeRangeButton"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Click="OnTimeRangeButtonClick"
                                            Tag="3"
                                            Content="∞"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            Background="#FF21262D"
                                            Foreground="#FFC9D1D9"
                                            BorderBrush="#FF30363D"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"/>
                                    <Grid.Styles>
                                        <Style Selector="Button.time-range-pill:pointerover">
                                            <Setter Property="Background" Value="#FF30363D"/>
                                            <Setter Property="BorderBrush" Value="#FF8B949E"/>
                                            <Setter Property="Foreground" Value="#FFC9D1D9"/>
                                        </Style>
                                    </Grid.Styles>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SelectedLanguagesTitle}"
                                           Foreground="#FFC9D1D9"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#FF238636"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding SelectedCount}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding SelectedLanguages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                        <Border Background="{Binding AccentBrush}"
                                                CornerRadius="999"
                                                Padding="10,6"
                                                Margin="0,0,6,6">
                                            <TextBlock Text="{Binding Language}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SuggestionsTitle}"
                                           Foreground="#FFC9D1D9"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="#FF21262D"
                                        CornerRadius="999"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding VisibleCount}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding RefreshCommand}"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        Background="#FF21262D"
                                        Foreground="#FFC9D1D9"
                                        BorderBrush="#FF30363D"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Classes="refresh-button">
                                    <Button.Styles>
                                        <Style Selector="Button.refresh-button:pointerover">
                                            <Setter Property="Background" Value="#FF30363D"/>
                                            <Setter Property="BorderBrush" Value="#FF8B949E"/>
                                        </Style>
                                        <Style Selector="Button.refresh-button:pressed">
                                            <Setter Property="Background" Value="#FF161B22"/>
                                        </Style>
                                    </Button.Styles>
                                    <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/refresh.svg"
                                                       Width="18"
                                                       Height="18"/>
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding MatchingLanguagesLabel}"
                                       Foreground="#FF8B949E"
                                       FontSize="12"/>

                            <Border Background="#FF0D1117"
                                    CornerRadius="16"
                                    BorderBrush="#FF30363D"
                                    BorderThickness="1"
                                    Padding="10">
                                <ScrollViewer Height="320"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                                <Border Background="#FF161B22"
                                                        BorderBrush="#FF30363D"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="6,*,Auto"
                                                          ColumnSpacing="12">
                                                        <Border Background="{Binding AccentBrush}"
                                                                CornerRadius="999"
                                                                Width="6"/>

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="4"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Language}"
                                                                       Foreground="#FFC9D1D9"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Foreground="#FFC9D1D9"
                                                                  VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer x:Name="TrendingScrollViewer"
                      Grid.Column="1"
                      Background="#FF0D1117"
                      Padding="20"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ClipToBounds="True"
                      PointerWheelChanged="OnTrendingScrollWheelChanged">
            <StackPanel Spacing="16"
                    Width="{Binding Viewport.Width, ElementName=TrendingScrollViewer}">
                <Border Background="#FF161B22"
                        BorderBrush="#FF30363D"
                        BorderThickness="1"
                        CornerRadius="18"
                        Margin="8,0,8,0"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Padding="22">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="12">
                        <StackPanel Grid.Row="0" Spacing="6">
                            <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingRepositoriesTitle}"
                                       Foreground="#FFC9D1D9"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Top">
                            <Border Background="#FF111827"
                                    BorderBrush="#FF30363D"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,5">
                                <TextBlock Text="{Binding SelectedCount}"
                                           Foreground="#FFE5E7EB"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <Border Background="#FF111827"
                                    BorderBrush="#FF30363D"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="10,5">
                                <TextBlock Text="{Binding VisibleCount}"
                                           Foreground="#FFE5E7EB"
                                           FontSize="11"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding TrendingLabel}"
                                   Foreground="#FF8B949E"
                                   FontSize="12"/>
                    </Grid>
                </Border>
                
                <Border Background="#FF161B22"
                        BorderBrush="#FF30363D"
                        BorderThickness="1"
                        CornerRadius="18"
                        Margin="8,0,8,0"
                        Padding="22">
                    <StackPanel Spacing="12">
                        <ItemsControl x:Name="TrendingItemsControl"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding TrendingRepositories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GithubTrendingRepository">
                                    <Border Background="#FF0D1117"
                                            BorderBrush="#FF30363D"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="0"
                                            Margin="0,0,0,12"
                                            Classes="repo-card"
                                            ClipToBounds="True"
                                            MinHeight="240">
                                        <Grid ColumnDefinitions="1.25*,1.75*,160"
                                              MinHeight="240">
                                            <Border Background="#FF161B22"
                                                    CornerRadius="14,0,0,14"
                                                    MinHeight="240"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding BannerImage}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="12"
                                                        Margin="18"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                               Foreground="#FFC9D1D9"
                                                               FontWeight="SemiBold"
                                                               FontSize="18"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="#FF8B949E"
                                                               FontSize="12"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <StackPanel Spacing="8"
                                                            IsVisible="{Binding HasContributors}">
                                                    <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=ContributorsTitle}"
                                                               Foreground="#FFC9D1D9"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Opacity="0.9"/>

                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <ItemsControl ItemsSource="{Binding Contributors}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:GithubContributorPreview">
                                                                    <Border Width="32"
                                                                            Height="32"
                                                                            CornerRadius="999"
                                                                            ClipToBounds="True"
                                                                            Margin="0,0,6,0"
                                                                            BorderBrush="#FF334155"
                                                                            BorderThickness="1">
                                                                        <Image Source="{Binding AvatarImage}"
                                                                               Stretch="UniformToFill"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </Grid>
                                                </StackPanel>

                                                <WrapPanel>
                                                    <Border Background="{Binding LanguageBrush}"
                                                            CornerRadius="999"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LanguageBadgeText}"
                                                                   Foreground="White"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                    <Border Background="#FF21262D"
                                                            CornerRadius="999"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LicenseBadgeText}"
                                                                   Foreground="#FFC9D1D9"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                    <Border Background="#FF21262D"
                                                            CornerRadius="999"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LastUpdatedBadgeText}"
                                                                   Foreground="#FFC9D1D9"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>

                                                </WrapPanel>

                                                <ItemsControl ItemsSource="{Binding Topics}"
                                                              IsVisible="{Binding HasTopics}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FF21262D"
                                                                    BorderBrush="#FF30363D"
                                                                    BorderThickness="1"
                                                                    CornerRadius="999"
                                                                    Padding="10,5"
                                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="#FFC9D1D9"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="#FF0D1117"
                                                    BorderBrush="#FF30363D"
                                                    BorderThickness="1,0,0,0"
                                                    Padding="14"
                                                    ClipToBounds="True">
                                                <StackPanel Spacing="8"
                                                            VerticalAlignment="Top">
                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding ViewModel.OpenRepositoryCommand, ElementName=MainWindowRoot}"
                                                            CommandParameter="{Binding}">
                                                        <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/open.svg"
                                                                           Width="22"
                                                                           Height="22"/>
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding ViewModel.StarRepositoryCommand, ElementName=MainWindowRoot}"
                                                            CommandParameter="{Binding}">
                                                        <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/star.svg"
                                                                           Width="22"
                                                                           Height="22"/>
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding ViewModel.WatchRepositoryCommand, ElementName=MainWindowRoot}"
                                                            CommandParameter="{Binding}">
                                                        <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/watch.svg"
                                                                           Width="22"
                                                                           Height="22"/>
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch">
                                                        <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/delete.svg"
                                                                           Width="22"
                                                                           Height="22"/>
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch">
                                                        <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/save.svg"
                                                                           Width="22"
                                                                           Height="22"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>




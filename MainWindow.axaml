<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="MainWindowRoot"
        xmlns:vm="using:Github_Trend"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:Github_Trend.Controls"
        xmlns:loc="using:Github_Trend.Localization"
        mc:Ignorable="d"
        x:DataType="vm:MainWindowViewModel"
        x:Class="Github_Trend.MainWindow"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        UseLayoutRounding="True"
        WindowState="Maximized"
        Icon="avares://Github-Trend/Assets/icon.ico"
        Title="GitHub Trend">
    <Window.Styles>
        <Style Selector="Border.repo-card">
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Button.repo-action-button">
            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="Button.repo-action-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
        </Style>
    </Window.Styles>
    <Grid ColumnDefinitions="360,*">
        <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          ClipToBounds="True">
                <StackPanel Margin="16" Spacing="14">

                    <!-- Settings Button & Profile Header -->
                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource CornerLarge}"
                            Padding="{DynamicResource PaddingLarge}">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Text="GitHub Trend"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="Bold"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding Auth.SignInCommand}"
                                    Padding="8"
                                    Background="{DynamicResource AccentPrimaryBrush}"
                                    Foreground="{DynamicResource TextOnAccentBrush}"
                                    BorderBrush="{DynamicResource AccentSecondaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerSmall}">
                                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/github.svg"
                                                   Width="18"
                                                   Height="18" />
                            </Button>
                            <Button Grid.Column="2"
                                    Click="OnSettingsButtonClick"
                                    Margin="8,0,0,0"
                                    Padding="8"
                                    Background="{DynamicResource BackgroundTertiaryBrush}"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerSmall}">
                                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/settings.svg"
                                                   Width="18"
                                                   Height="18" />
                            </Button>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource CornerLarge}"
                            Padding="{DynamicResource PaddingLarge}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SearchTitle}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold" />
                            <TextBox Text="{Binding Filter.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource BackgroundPrimaryBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                     CaretBrush="{DynamicResource AccentSecondaryBrush}"
                                     CornerRadius="{DynamicResource CornerSmall}" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource CornerLarge}"
                            Padding="{DynamicResource PaddingLarge}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Row="0" Spacing="2">
                                    <TextBlock
                                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingPeriodTitle}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        FontWeight="SemiBold" />
                                    <TextBlock
                                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingPeriodSubtitle}"
                                        Foreground="{DynamicResource TextSecondaryBrush}"
                                        FontSize="{DynamicResource FontSizeXSmall}" />
                                </StackPanel>
                            </Grid>

                            <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerMedium}"
                                    Padding="8">
                                <Grid ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8"
                                      RowSpacing="8">
                                    <Button Command="{Binding SelectDailyCommand}"
                                            Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeDaily}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"
                                            Classes.selected="{Binding IsDailySelected}" />
                                    <Button Grid.Row="0" Grid.Column="1"
                                            Command="{Binding SelectWeeklyCommand}"
                                            Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeWeekly}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"
                                            Classes.selected="{Binding IsWeeklySelected}" />
                                    <Button Grid.Row="1" Grid.Column="0"
                                            Command="{Binding SelectMonthlyCommand}"
                                            Content="{Binding Source={x:Static loc:Localization.Instance}, Path=TimeRangeMonthly}"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"
                                            Classes.selected="{Binding IsMonthlySelected}" />
                                    <Button Grid.Row="1" Grid.Column="1"
                                            Command="{Binding SelectAllCommand}"
                                            Content="∞"
                                            Height="44"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center"
                                            Padding="12"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            FontWeight="SemiBold"
                                            Classes="time-range-pill"
                                            Classes.selected="{Binding IsAllSelected}" />
                                    <Grid.Styles>
                                        <Style Selector="Button.time-range-pill">
                                            <Setter Property="Background" Value="{DynamicResource BackgroundTertiaryBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderPrimaryBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </Style>
                                        <Style Selector="Button.time-range-pill.selected">
                                            <Setter Property="Background" Value="{DynamicResource AccentPrimaryBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentSecondaryBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
                                        </Style>
                                        <Style Selector="Button.time-range-pill:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        </Style>
                                    </Grid.Styles>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource CornerLarge}"
                            Padding="{DynamicResource PaddingLarge}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock
                                    Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SelectedLanguagesTitle}"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                                <Border Grid.Column="1"
                                        Background="{DynamicResource AccentPrimaryBrush}"
                                        CornerRadius="{DynamicResource CornerPill}"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding Filter.SelectedCount}"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Filter.SelectedLanguages}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                        <Border Background="{Binding AccentBrush}"
                                                CornerRadius="{DynamicResource CornerPill}"
                                                Padding="10,6"
                                                Margin="0,0,6,6">
                                            <TextBlock Text="{Binding Language}"
                                                       Foreground="{DynamicResource TextOnAccentBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource CornerLarge}"
                            Padding="{DynamicResource PaddingLarge}">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <TextBlock
                                    Text="{Binding Source={x:Static loc:Localization.Instance}, Path=SuggestionsTitle}"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center" />
                                <Border Grid.Column="1"
                                        Background="{DynamicResource BackgroundTertiaryBrush}"
                                        CornerRadius="{DynamicResource CornerPill}"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding Filter.VisibleCount}"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Button Grid.Column="2"
                                        Command="{Binding RefreshCommand}"
                                        Margin="8,0,0,0"
                                        Padding="8,4"
                                        Background="{DynamicResource BackgroundTertiaryBrush}"
                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                        BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource CornerSmall}"
                                        Classes="refresh-button">
                                    <Button.Styles>
                                        <Style Selector="Button.refresh-button:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
                                        </Style>
                                        <Style Selector="Button.refresh-button:pressed">
                                            <Setter Property="Background" Value="{DynamicResource PressedBackgroundBrush}" />
                                        </Style>
                                    </Button.Styles>
                                    <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/refresh.svg"
                                                       Width="18"
                                                       Height="18" />
                                </Button>
                            </Grid>

                            <TextBlock Text="{Binding Filter.MatchingLanguagesLabel}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="{DynamicResource FontSizeSmall}" />

                            <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                                    CornerRadius="16"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    Padding="10">
                                <ScrollViewer Height="320"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Filter.FilteredLanguages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:LanguageOptionViewModel">
                                                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                        BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="{DynamicResource CornerLarge}"
                                                        Padding="12"
                                                        Margin="0,0,0,8">
                                                    <Grid ColumnDefinitions="6,*,Auto"
                                                          ColumnSpacing="12">
                                                        <Border Background="{Binding AccentBrush}"
                                                                CornerRadius="{DynamicResource CornerPill}"
                                                                Width="6" />

                                                        <StackPanel Grid.Column="1"
                                                                    Spacing="4"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Language}"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>

                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                                                  VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer x:Name="TrendingScrollViewer"
                      Grid.Column="1"
                      Background="{DynamicResource BackgroundPrimaryBrush}"
                      Padding="20"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      ClipToBounds="True"
                      PointerWheelChanged="OnTrendingScrollWheelChanged">
            <StackPanel Spacing="16"
                        Width="{Binding Viewport.Width, ElementName=TrendingScrollViewer}">
                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderPrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerXLarge}"
                        Margin="8,0,8,0"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True"
                        Padding="{DynamicResource PaddingXLarge}">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="12">
                        <StackPanel Grid.Row="0" Spacing="6">
                            <TextBlock
                                Text="{Binding Source={x:Static loc:Localization.Instance}, Path=TrendingRepositoriesTitle}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="{DynamicResource FontSizeXLarge}"
                                FontWeight="SemiBold"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Top">
                            <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerPill}"
                                    Padding="10,5">
                                <TextBlock Text="{Binding Filter.SelectedCount}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="{DynamicResource FontSizeXSmall}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <Border Background="{DynamicResource BackgroundElevatedBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerPill}"
                                    Padding="10,5">
                                <TextBlock Text="{Binding Filter.VisibleCount}"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           FontSize="{DynamicResource FontSizeXSmall}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding TrendingLabel}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="{DynamicResource FontSizeSmall}" />
                    </Grid>
                </Border>

                <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                        BorderBrush="{DynamicResource BorderPrimaryBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CornerXLarge}"
                        Margin="8,0,8,0"
                        Padding="{DynamicResource PaddingXLarge}">
                    <StackPanel Spacing="12">
                        <ItemsControl x:Name="TrendingItemsControl"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding TrendingRepositories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GithubTrendingRepository">
                                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource CornerMedium}"
                                            Padding="0"
                                            Margin="0,0,0,12"
                                            Classes="repo-card"
                                            ClipToBounds="True"
                                            MinHeight="240">
                                        <Grid ColumnDefinitions="1.25*,1.75*,160"
                                              MinHeight="240">
                                            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                                                    CornerRadius="14,0,0,14"
                                                    MinHeight="240"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding BannerImage}"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="12"
                                                        Margin="18"
                                                        VerticalAlignment="Stretch"
                                                        HorizontalAlignment="Stretch">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding DisplayTitle}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontWeight="SemiBold"
                                                               FontSize="{DynamicResource FontSizeLarge}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="{DynamicResource FontSizeSmall}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <StackPanel Spacing="8"
                                                            IsVisible="{Binding HasContributors}">
                                                    <TextBlock
                                                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=ContributorsTitle}"
                                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                                        FontSize="{DynamicResource FontSizeXSmall}"
                                                        FontWeight="SemiBold"
                                                        Opacity="0.9" />

                                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                        <ItemsControl ItemsSource="{Binding Contributors}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:GithubContributorPreview">
                                                                    <Border Width="32"
                                                                            Height="32"
                                                                            CornerRadius="{DynamicResource CornerPill}"
                                                                            ClipToBounds="True"
                                                                            Margin="0,0,6,0"
                                                                            BorderBrush="{DynamicResource BorderSecondaryBrush}"
                                                                            BorderThickness="1">
                                                                        <Image Source="{Binding AvatarImage}"
                                                                               Stretch="UniformToFill" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                    </Grid>
                                                </StackPanel>

                                                <WrapPanel>
                                                    <Border Background="{Binding LanguageBrush}"
                                                            CornerRadius="{DynamicResource CornerPill}"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LanguageBadgeText}"
                                                                   Foreground="{DynamicResource TextOnAccentBrush}"
                                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>

                                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                            CornerRadius="{DynamicResource CornerPill}"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LicenseBadgeText}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>

                                                    <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                            CornerRadius="{DynamicResource CornerPill}"
                                                            Padding="10,5"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding LastUpdatedBadgeText}"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   FontSize="{DynamicResource FontSizeXSmall}"
                                                                   FontWeight="SemiBold" />
                                                    </Border>

                                                </WrapPanel>

                                                <ItemsControl ItemsSource="{Binding Topics}"
                                                              IsVisible="{Binding HasTopics}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource BackgroundTertiaryBrush}"
                                                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{DynamicResource CornerPill}"
                                                                    Padding="10,5"
                                                                    Margin="0,0,8,8">
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           FontSize="{DynamicResource FontSizeXSmall}"
                                                                           FontWeight="SemiBold" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="{DynamicResource BackgroundPrimaryBrush}"
                                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                                    BorderThickness="1,0,0,0"
                                                    Padding="{DynamicResource PaddingLarge}"
                                                    ClipToBounds="True">
                                                <StackPanel Spacing="8"
                                                            VerticalAlignment="Top">
                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding ViewModel.OpenRepositoryCommand, ElementName=MainWindowRoot}"
                                                            CommandParameter="{Binding}">
                                                        <controls:SvgImage
                                                            SourceUri="avares://Github-Trend/Assets/Icons/open.svg"
                                                            Width="22"
                                                            Height="22" />
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding ViewModel.StarRepositoryCommand, ElementName=MainWindowRoot}"
                                                            CommandParameter="{Binding}">
                                                        <controls:SvgImage
                                                            SourceUri="avares://Github-Trend/Assets/Icons/star.svg"
                                                            Width="22"
                                                            Height="22" />
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding ViewModel.WatchRepositoryCommand, ElementName=MainWindowRoot}"
                                                            CommandParameter="{Binding}">
                                                        <controls:SvgImage
                                                            SourceUri="avares://Github-Trend/Assets/Icons/watch.svg"
                                                            Width="22"
                                                            Height="22" />
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch">
                                                        <controls:SvgImage
                                                            SourceUri="avares://Github-Trend/Assets/Icons/delete.svg"
                                                            Width="22"
                                                            Height="22" />
                                                    </Button>

                                                    <Button Classes="repo-action-button"
                                                            HorizontalAlignment="Stretch">
                                                        <controls:SvgImage
                                                            SourceUri="avares://Github-Trend/Assets/Icons/save.svg"
                                                            Width="22"
                                                            Height="22" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

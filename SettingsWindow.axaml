<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Github_Trend"
        xmlns:controls="using:Github_Trend.Controls"
        xmlns:loc="using:Github_Trend.Localization"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
        x:Class="Github_Trend.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{DynamicResource BackgroundPrimaryBrush}"
        Width="600" Height="850"
        WindowStartupLocation="CenterOwner"
        Title="Settings">

    <ScrollViewer Margin="20">
        <StackPanel Spacing="20">
            <!-- Title -->
            <TextBlock Text="Settings"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="24"
                       FontWeight="Bold" />

            <!-- App Info -->
            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource CornerLarge}"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Application Settings"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               FontSize="16" />
                    <TextBlock Text="Version 1.0.0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeSmall}" />
                </StackPanel>
            </Border>

            <!-- GitHub Account Settings -->
            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource CornerLarge}"
                    Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock
                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=GitHubAccountSectionTitle}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        FontWeight="SemiBold"
                        FontSize="16" />

                    <TextBlock Text="{Binding Auth.AuthStatus}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding Auth.AccountSummary}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="{DynamicResource FontSizeXSmall}"
                               TextWrapping="Wrap" />

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            IsVisible="{Binding Auth.HasDeviceCode}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding Auth.DeviceCode}"
                                       Foreground="{DynamicResource AccentSecondaryBrush}"
                                       FontWeight="Bold"
                                       FontSize="{DynamicResource FontSizeLarge}"
                                       TextWrapping="Wrap" />
                            <Button Command="{Binding Auth.CopyDeviceCodeCommand}"
                                    Padding="10,6"
                                    Background="{DynamicResource BackgroundTertiaryBrush}"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource CornerSmall}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/save.svg"
                                                       Width="16" Height="16" />
                                    <TextBlock
                                        Text="{Binding Source={x:Static loc:Localization.Instance}, Path=CopyCodeButtonText}"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding Auth.SignInCommand}"
                                Padding="12,8"
                                Background="{DynamicResource AccentPrimaryBrush}"
                                Foreground="{DynamicResource TextOnAccentBrush}"
                                BorderBrush="{DynamicResource AccentSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CornerSmall}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/github.svg" Width="16"
                                                   Height="16" />
                                <TextBlock
                                    Text="{Binding Source={x:Static loc:Localization.Instance}, Path=GitHubSignInButtonText}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding Auth.RefreshSessionCommand}"
                                Padding="12,8"
                                Background="{DynamicResource BackgroundTertiaryBrush}"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderBrush="{DynamicResource BorderPrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CornerSmall}"
                                IsVisible="{Binding Auth.IsConnected}">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/refresh.svg" Width="16"
                                               Height="16" />
                        </Button>

                        <Button Command="{Binding Auth.SignOutCommand}"
                                Padding="12,8"
                                Background="{DynamicResource BackgroundTertiaryBrush}"
                                Foreground="{DynamicResource ErrorBrush}"
                                BorderBrush="{DynamicResource BorderHoverBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource CornerSmall}"
                                IsVisible="{Binding Auth.IsConnected}">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/delete.svg" Width="16"
                                               Height="16" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Debug Information & Logs Section -->
            <Border Background="{DynamicResource BackgroundSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource CornerLarge}"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Debug Information"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               FontSize="16" />

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock Text="{Binding Debug.DebugInfo}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="10"
                                   FontFamily="Courier New"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Application Logs"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,12,0,0" />

                    <Border Background="{DynamicResource BackgroundPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Height="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding Debug.AppLogs}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10"
                                       FontFamily="Courier New"
                                       TextWrapping="Wrap" />
                        </ScrollViewer>
                    </Border>

                    <Button Command="{Binding Debug.CopyLogsCommand}"
                            HorizontalAlignment="Left"
                            Padding="16,10"
                            Background="{DynamicResource BackgroundTertiaryBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource BorderPrimaryBrush}"
                            BorderThickness="1"
                            CornerRadius="{DynamicResource CornerSmall}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/save.svg" Width="16"
                                               Height="16" />
                            <TextBlock Text="Copy Debug Info &amp; Logs" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    Padding="20,10"
                    Background="{DynamicResource BackgroundTertiaryBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderBrush="{DynamicResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="{DynamicResource CornerSmall}"
                    Click="OnCloseClick" />
        </StackPanel>
    </ScrollViewer>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Github_Trend"
        xmlns:controls="using:Github_Trend.Controls"
        xmlns:loc="using:Github_Trend.Localization"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
        x:Class="Github_Trend.SettingsWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="#FF0D1117"
        Width="600" Height="850"
        WindowStartupLocation="CenterOwner"
        Title="Settings">
    
    <ScrollViewer Margin="20">
        <StackPanel Spacing="20">
            <!-- Title -->
            <TextBlock Text="Settings"
                       Foreground="#FFC9D1D9"
                       FontSize="24"
                       FontWeight="Bold"/>

            <!-- App Info / Theme placeholder -->
            <Border Background="#FF161B22"
                    BorderBrush="#FF30363D"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Application Settings"
                               Foreground="#FFC9D1D9"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    <TextBlock Text="Version 1.0.0"
                               Foreground="#FF8B949E"
                               FontSize="12"/>
                    <!-- Additional settings could go here -->
                </StackPanel>
            </Border>

            <!-- GitHub Account Settings -->
            <Border Background="#FF161B22"
                    BorderBrush="#FF30363D"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">
                <StackPanel Spacing="16">
                    <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=GitHubAccountSectionTitle}"
                               Foreground="#FFC9D1D9"
                               FontWeight="SemiBold"
                               FontSize="16"/>

                    <TextBlock Text="{Binding GitHubAuthStatus}"
                               Foreground="#FFC9D1D9"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding GitHubAccountSummary}"
                               Foreground="#FF8B949E"
                               FontSize="11"
                               TextWrapping="Wrap"/>

                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            IsVisible="{Binding HasGitHubDeviceCode}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding GitHubDeviceCode}"
                                       Foreground="#FF2EA043"
                                       FontWeight="Bold"
                                       FontSize="18"
                                       TextWrapping="Wrap"/>
                            <Button Command="{Binding CopyGitHubCodeCommand}"
                                    Padding="10,6"
                                    Background="#FF21262D"
                                    Foreground="#FFC9D1D9"
                                    BorderBrush="#FF30363D"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/save.svg" Width="16" Height="16"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=CopyCodeButtonText}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding GitHubSignInCommand}"
                                Padding="12,8"
                                Background="#FF238636"
                                Foreground="White"
                                BorderBrush="#FF2EA043"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/github.svg" Width="16" Height="16"/>
                                <TextBlock Text="{Binding Source={x:Static loc:Localization.Instance}, Path=GitHubSignInButtonText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding GitHubRefreshCommand}"
                                Padding="12,8"
                                Background="#FF21262D"
                                Foreground="#FFC9D1D9"
                                BorderBrush="#FF30363D"
                                BorderThickness="1"
                                CornerRadius="8"
                                IsVisible="{Binding IsGitHubConnected}">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/refresh.svg" Width="16" Height="16"/>
                        </Button>

                        <Button Command="{Binding GitHubSignOutCommand}"
                                Padding="12,8"
                                Background="#FF21262D"
                                Foreground="#FFF85149"
                                BorderBrush="#FF8B949E"
                                BorderThickness="1"
                                CornerRadius="8"
                                IsVisible="{Binding IsGitHubConnected}">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/delete.svg" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Debug Information & Logs Section -->
            <Border Background="#FF161B22"
                    BorderBrush="#FF30363D"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="Debug Information"
                               Foreground="#FFC9D1D9"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    
                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <TextBlock Text="{Binding DebugInfo}"
                                   Foreground="#FF8B949E"
                                   FontSize="10"
                                   FontFamily="Courier New"
                                   TextWrapping="Wrap"/>
                    </Border>
                    
                    <TextBlock Text="Application Logs"
                               Foreground="#FFC9D1D9"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,12,0,0"/>
                    
                    <Border Background="#FF0D1117"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Height="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding AppLogs}"
                                       Foreground="#FF8B949E"
                                       FontSize="10"
                                       FontFamily="Courier New"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Border>
                    
                    <Button Click="OnCopyLogsClick"
                            HorizontalAlignment="Left"
                            Padding="16,10"
                            Background="#FF21262D"
                            Foreground="#FFC9D1D9"
                            BorderBrush="#FF30363D"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <controls:SvgImage SourceUri="avares://Github-Trend/Assets/Icons/save.svg" Width="16" Height="16"/>
                            <TextBlock Text="Copy Debug Info &amp; Logs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <Button Content="Close"
                    HorizontalAlignment="Right"
                    Padding="20,10"
                    Background="#FF21262D"
                    Foreground="#FFC9D1D9"
                    BorderBrush="#FF30363D"
                    BorderThickness="1"
                    CornerRadius="8"
                    Click="OnCloseClick"/>
        </StackPanel>
    </ScrollViewer>
</Window>

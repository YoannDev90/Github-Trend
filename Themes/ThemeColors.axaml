<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ResourceDictionary.ThemeDictionaries>
        <!-- DARK THEME -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="BackgroundPrimaryColor">#FF0D1117</Color>
            <Color x:Key="BackgroundSecondaryColor">#FF161B22</Color>
            <Color x:Key="BackgroundTertiaryColor">#FF21262D</Color>
            <Color x:Key="BackgroundElevatedColor">#FF1C2333</Color>

            <Color x:Key="BorderPrimaryColor">#FF30363D</Color>
            <Color x:Key="BorderSecondaryColor">#FF334155</Color>
            <Color x:Key="BorderHoverColor">#FF8B949E</Color>

            <Color x:Key="TextPrimaryColor">#FFE6EDF3</Color>
            <Color x:Key="TextSecondaryColor">#FF8B949E</Color>
            <Color x:Key="TextTertiaryColor">#FF6E7681</Color>
            <Color x:Key="TextOnAccentColor">#FFFFFFFF</Color>

            <Color x:Key="AccentPrimaryColor">#FF238636</Color>
            <Color x:Key="AccentSecondaryColor">#FF2EA043</Color>
            <Color x:Key="AccentHoverColor">#FF3FB950</Color>

            <Color x:Key="ErrorColor">#FFF85149</Color>
            <Color x:Key="WarningColor">#FFD29922</Color>
            <Color x:Key="SuccessColor">#FF238636</Color>
            <Color x:Key="InfoColor">#FF2F81F7</Color>

            <Color x:Key="HoverBackgroundColor">#FF30363D</Color>
            <Color x:Key="PressedBackgroundColor">#FF161B22</Color>
            <Color x:Key="CardBackgroundColor">#FF161B22</Color>

            <Color x:Key="SurfaceShadowColor">#00000000</Color>
            <Color x:Key="StarActiveColor">#FFEAC54D</Color>
            <Color x:Key="WatchActiveColor">#FF2EA043</Color>
        </ResourceDictionary>

        <!-- LIGHT THEME -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="BackgroundPrimaryColor">#FFFFFFFF</Color>
            <Color x:Key="BackgroundSecondaryColor">#FFF6F8FA</Color>
            <Color x:Key="BackgroundTertiaryColor">#FFEBEEF1</Color>
            <Color x:Key="BackgroundElevatedColor">#FFFFFFFF</Color>

            <Color x:Key="BorderPrimaryColor">#FFD0D7DE</Color>
            <Color x:Key="BorderSecondaryColor">#FFE1E4E8</Color>
            <Color x:Key="BorderHoverColor">#FF6E7681</Color>

            <Color x:Key="TextPrimaryColor">#FF1F2328</Color>
            <Color x:Key="TextSecondaryColor">#FF656D76</Color>
            <Color x:Key="TextTertiaryColor">#FF8C959F</Color>
            <Color x:Key="TextOnAccentColor">#FFFFFFFF</Color>

            <Color x:Key="AccentPrimaryColor">#FF238636</Color>
            <Color x:Key="AccentSecondaryColor">#FF2EA043</Color>
            <Color x:Key="AccentHoverColor">#FF3FB950</Color>

            <Color x:Key="ErrorColor">#FFCF2222</Color>
            <Color x:Key="WarningColor">#FF9A6700</Color>
            <Color x:Key="SuccessColor">#FF238636</Color>
            <Color x:Key="InfoColor">#FF0969DA</Color>

            <Color x:Key="HoverBackgroundColor">#FFE8ECF0</Color>
            <Color x:Key="PressedBackgroundColor">#FFD0D7DE</Color>
            <Color x:Key="CardBackgroundColor">#FFFFFFFF</Color>

            <Color x:Key="SurfaceShadowColor">#22000000</Color>
            <Color x:Key="StarActiveColor">#FFD29922</Color>
            <Color x:Key="WatchActiveColor">#FF238636</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Shared Brushes (resolved from theme dictionaries via DynamicResource) -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{DynamicResource BackgroundPrimaryColor}" />
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{DynamicResource BackgroundSecondaryColor}" />
    <SolidColorBrush x:Key="BackgroundTertiaryBrush" Color="{DynamicResource BackgroundTertiaryColor}" />
    <SolidColorBrush x:Key="BackgroundElevatedBrush" Color="{DynamicResource BackgroundElevatedColor}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource CardBackgroundColor}" />

    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="{DynamicResource BorderPrimaryColor}" />
    <SolidColorBrush x:Key="BorderSecondaryBrush" Color="{DynamicResource BorderSecondaryColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush" Color="{DynamicResource BorderHoverColor}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{DynamicResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{DynamicResource TextOnAccentColor}" />

    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{DynamicResource AccentPrimaryColor}" />
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{DynamicResource AccentSecondaryColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{DynamicResource AccentHoverColor}" />

    <SolidColorBrush x:Key="ErrorBrush" Color="{DynamicResource ErrorColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{DynamicResource WarningColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{DynamicResource SuccessColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{DynamicResource InfoColor}" />

    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{DynamicResource HoverBackgroundColor}" />
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="{DynamicResource PressedBackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceShadowBrush" Color="{DynamicResource SurfaceShadowColor}" />
    <SolidColorBrush x:Key="StarActiveBrush" Color="{DynamicResource StarActiveColor}" />
    <SolidColorBrush x:Key="WatchActiveBrush" Color="{DynamicResource WatchActiveColor}" />

    <!-- Corner Radius -->
    <x:Double x:Key="CornerRadiusSmall">6</x:Double>
    <x:Double x:Key="CornerRadiusMedium">10</x:Double>
    <x:Double x:Key="CornerRadiusLarge">12</x:Double>
    <x:Double x:Key="CornerRadiusXLarge">16</x:Double>
    <x:Double x:Key="CornerRadiusPill">999</x:Double>

    <CornerRadius x:Key="CornerSmall">6</CornerRadius>
    <CornerRadius x:Key="CornerMedium">10</CornerRadius>
    <CornerRadius x:Key="CornerLarge">12</CornerRadius>
    <CornerRadius x:Key="CornerXLarge">16</CornerRadius>
    <CornerRadius x:Key="CornerPill">999</CornerRadius>

    <!-- Spacing -->
    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">12</x:Double>
    <x:Double x:Key="SpacingLarge">16</x:Double>
    <x:Double x:Key="SpacingXLarge">20</x:Double>

    <Thickness x:Key="PaddingSmall">8</Thickness>
    <Thickness x:Key="PaddingMedium">12</Thickness>
    <Thickness x:Key="PaddingLarge">16</Thickness>
    <Thickness x:Key="PaddingXLarge">24</Thickness>

    <!-- Font Sizes -->
    <x:Double x:Key="FontSizeXSmall">11</x:Double>
    <x:Double x:Key="FontSizeSmall">12</x:Double>
    <x:Double x:Key="FontSizeMedium">13</x:Double>
    <x:Double x:Key="FontSizeLarge">16</x:Double>
    <x:Double x:Key="FontSizeXLarge">24</x:Double>
</ResourceDictionary>
